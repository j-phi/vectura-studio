dropshape", "callee": "push", "source_file": "/Users/jayphi/Documents/github/vectura-studio/src/core/algorithms/rainfall.js", "source_location": "L377"}, {"caller_nid": "rainfall_builddropshape", "callee": "max", "source_file": "/Users/jayphi/Documents/github/vectura-studio/src/core/algorithms/rainfall.js", "source_location": "L382"}, {"caller_nid": "rainfall_builddropshape", "callee": "(() => {\n              if (dropShape === 'circle') {\n                const pts = [];\n                const steps = 32;\n                for (let i = 0; i < steps; i++) {\n                  const t = (i / steps) * Math.PI * 2;\n                  pts.push({ x: Math.cos(t) * fillSize, y: Math.sin(t) * fillSize });\n                }\n                return pts;\n              }\n              if (dropShape === 'square') {\n                return [\n                  { x: -fillSize, y: -fillSize },\n                  { x: fillSize, y: -fillSize },\n                  { x: fillSize, y: fillSize },\n                  { x: -fillSize, y: fillSize },\n                ];\n              }\n              const arcSteps = 18;\n              const headR = fillSize;\n              const headY = headR * 0.6;\n              const tailY = -headR * 1.4;\n              const pts = [];\n              for (let i = 0; i <= arcSteps; i++) {\n                const t = i / arcSteps;\n                const theta = t * Math.PI;\n                pts.push({ x: Math.cos(theta) * headR, y: Math.sin(theta) * headR + headY });\n              }\n              pts.push({ x: 0, y: tailY });\n              return pts;\n            })", "source_file": "/Users/jayphi/Documents/github/vectura-studio/src/core/algorithms/rainfall.js", "source_location": "L385"}, {"caller_nid": "rainfall_builddropshape", "callee": "map", "source_file": "/Users/jayphi/Documents/github/vectura-studio/src/core/algorithms/rainfall.js", "source_location": "L417"}, {"caller_nid": "rainfall_builddropshape", "callee": "map", "source_file": "/Users/j