#!/bin/sh
# graphify-pre-commit-start
# Runs graphify AST update and stages output before each commit (no LLM needed).

STAGED=$(git diff --cached --name-only 2>/dev/null)
if [ -z "$STAGED" ]; then
    exit 0
fi

# Detect the correct Python interpreter (handles pipx, venv, system installs)
GRAPHIFY_BIN=$(command -v graphify 2>/dev/null)
if [ -n "$GRAPHIFY_BIN" ]; then
    _SHEBANG=$(head -1 "$GRAPHIFY_BIN" | sed 's/^#![[:space:]]*//')
    case "$_SHEBANG" in
        */env\ *) GRAPHIFY_PYTHON="${_SHEBANG#*/env }" ;;
        *)         GRAPHIFY_PYTHON="$_SHEBANG" ;;
    esac
    # Allowlist: only keep characters valid in a filesystem path to prevent
    # injection if the shebang contains shell metacharacters
    case "$GRAPHIFY_PYTHON" in
        *[!a-zA-Z0-9/_.-]*) GRAPHIFY_PYTHON="" ;;
    esac
    if [ -n "$GRAPHIFY_PYTHON" ] && ! "$GRAPHIFY_PYTHON" -c "import graphify" >/dev/null 2>&1; then
        GRAPHIFY_PYTHON=""
    fi
fi
# Fall back: try python3, then python (Windows has no python3 shim)
if [ -z "$GRAPHIFY_PYTHON" ]; then
    if command -v python3 >/dev/null 2>&1 && python3 -c "import graphify" >/dev/null 2>&1; then
        GRAPHIFY_PYTHON="python3"
    elif command -v python >/dev/null 2>&1 && python -c "import graphify" >/dev/null 2>&1; then
        GRAPHIFY_PYTHON="python"
    else
        exit 0
    fi
fi

export GRAPHIFY_STAGED="$STAGED"
$GRAPHIFY_PYTHON -P -c "
import os, sys
from pathlib import Path

staged_raw = os.environ.get('GRAPHIFY_STAGED', '')
staged = [Path(f.strip()) for f in staged_raw.strip().splitlines() if f.strip()]

if not staged:
    sys.exit(0)

print(f'[graphify hook] {len(staged)} file(s) staged — updating graph...')

try:
    from graphify.watch import _rebuild_code
    _rebuild_code(Path('.'))
except Exception as exc:
    print(f'[graphify hook] Rebuild failed: {exc}')
    sys.exit(1)
" || exit 1

# graphify-out is regenerated above for local navigation but is NOT committed —
# it is gitignored (see .gitignore). Do not stage it.
# graphify-pre-commit-end

# user-presets-bundle-start
# Rebuild the user-preset + wallpaper-recipe bundles whenever a .vectura file
# under user-presets/ is staged, then stage the regenerated config so the bundle
# never drifts from its source files.
VECTURA_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '^user-presets/.*\.vectura$' || true)
if [ -n "$VECTURA_FILES" ]; then
    echo "[pre-commit] user-presets staged — rebuilding bundles..."
    node scripts/build-user-presets.js || exit 1
    node scripts/build-user-wallpaper-recipes.js || exit 1
    git add src/config/user-presets.js src/config/user-wallpaper-recipes.js
fi
# user-presets-bundle-end

# selector-lint-start
# Warn (non-blocking) when staged tests/e2e/*.js files introduce role+name lookups
# like getByRole('button', { name: 'Foo' }). These break when labels are renamed;
# prefer id-based locators (page.locator('#btn-foo')) when the target has an id.
E2E_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '^tests/e2e/.*\.js$' || true)
if [ -n "$E2E_FILES" ]; then
    SELECTOR_LINT_TMP=$(mktemp 2>/dev/null || echo "/tmp/selector-lint-$$.txt")
    : > "$SELECTOR_LINT_TMP"
    SELECTOR_LINT_COUNT=0
    # Iterate over each staged e2e file
    echo "$E2E_FILES" | while IFS= read -r f; do
        [ -z "$f" ] && continue
        # Grab added lines (those starting with '+' but not '+++') containing the pattern.
        # -U0 keeps context small; we only inspect additions.
        git diff --cached -U0 -- "$f" 2>/dev/null \
            | grep -E '^\+[^+].*getByRole\([^)]*name:' \
            | sed 's/^\+//' \
            | while IFS= read -r line; do
                # Trim leading whitespace for readability
                trimmed=$(printf '%s' "$line" | sed 's/^[[:space:]]*//')
                printf '  %s: %s\n' "$f" "$trimmed" >> "$SELECTOR_LINT_TMP"
            done
    done
    MATCH_COUNT=$(wc -l < "$SELECTOR_LINT_TMP" 2>/dev/null | tr -d ' ')
    if [ -n "$MATCH_COUNT" ] && [ "$MATCH_COUNT" -gt 0 ]; then
        echo ""
        echo "[pre-commit warning] e2e selector stability: $MATCH_COUNT new \`getByRole({name:})\` lookup(s) detected"
        cat "$SELECTOR_LINT_TMP"
        echo "Prefer id-based locators (page.locator('#btn-foo')) when the element has an id —"
        echo "text/role lookups break when labels are renamed. Use role/name only when the accessible"
        echo "name itself is the assertion target. (This is a warning, not a block.)"
        echo ""
    fi
    rm -f "$SELECTOR_LINT_TMP"
fi
# selector-lint-end

exit 0
