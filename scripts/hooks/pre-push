#!/bin/sh
# Pre-push gate: runs `npm run test:fast` (~12s — unit + integration +
# visual + perf) before every push. Skips e2e by design; CI gates the
# full suite on the remote.
#
# Bypass: SKIP_PREPUSH=1 git push   (use sparingly)
#
# Skipped automatically for branch deletions.

if [ "$SKIP_PREPUSH" = "1" ]; then
  echo "[pre-push] SKIP_PREPUSH=1 — skipping local test suite. CI will gate."
  exit 0
fi

empty_sha="0000000000000000000000000000000000000000"
any_real=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$empty_sha" ] && continue
  any_real=1
done
if [ "$any_real" = "0" ]; then
  echo "[pre-push] Delete-only push — skipping test suite."
  exit 0
fi

echo "[pre-push] Running test:fast (unit + integration + visual + perf, ~12s)…"
echo "[pre-push] Bypass: SKIP_PREPUSH=1 git push   (only when intentional)"
echo

if ! npm run test:fast; then
  echo
  echo "[pre-push] ❌ test:fast failed. Push aborted."
  echo "[pre-push]    Fix the failures, or rerun with SKIP_PREPUSH=1 git push if intentional."
  exit 1
fi

echo
echo "[pre-push] ✅ test:fast passed. (e2e gated by CI, not local hook.)"
exit 0
